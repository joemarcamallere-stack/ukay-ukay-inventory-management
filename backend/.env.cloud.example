# Supabase cloud — copy this file to .env.cloud and fill in your credentials
# Format: postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?uselibpqcompat=true&sslmode=require"
JWT_SECRET="your-secret-here"

# Apply migrations to this cloud database with:
# npm run db:migrate:cloud -w backend
