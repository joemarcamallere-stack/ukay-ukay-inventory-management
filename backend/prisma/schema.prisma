// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessModule {
  UKAY
  RESTAURANT
}

enum InventoryItemType {
  UKAY_ITEM
  INGREDIENT
  MENU_ITEM
  SUPPLY
  BUNDLE
}

model Business {
  id        String           @id @default(uuid())
  name      String           @unique
  modules   BusinessModule[] @default([UKAY])
  users     User[]
  locations Location[]
  items     InventoryItem[]
  stockMovements StockMovement[]
  recipes   Recipe[]
  kitchenOrders KitchenOrder[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  passwordHash String
  role      String   // Admin, Manager, Staff
  status    String   // Active, Inactive
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  stockMovements StockMovement[]
  kitchenOrders KitchenOrder[]
  lastLogin DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String
  manager   String
  phone     String
  itemCount Int      @default(0)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  items     InventoryItem[]
  stockMovements StockMovement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
}

model InventoryItem {
  id             String   @id @default(uuid())
  name           String
  itemType       InventoryItemType @default(UKAY_ITEM)
  sku            String?
  category       String
  targetCustomer String?  // Male, Female, Unisex
  subcategory    String?
  size           String?
  condition      String?  // Excellent, Good, Fair, Damaged
  quantity       Float    @default(0.0)
  price          Float    @default(0.0)
  unit           String?
  minStock       Float?
  maxStock       Float?
  reorderPoint   Float?
  expiryDate     DateTime?
  storageTemperature String?
  dateAdded      DateTime @default(now())
  locationId     String
  location       Location @relation(fields: [locationId], references: [id])
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  stockMovements StockMovement[]
  recipeIngredients RecipeIngredient[]
  menuRecipes Recipe[] @relation("RecipeMenuItem")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, itemType])
  @@index([businessId, locationId])
  @@unique([businessId, sku])
}

model Recipe {
  id              String             @id @default(uuid())
  name            String
  category        String
  servings        Float
  yieldPercentage Float              @default(100.0)
  prepTimeMinutes Int?
  instructions    String?
  targetFoodCost  Float?
  sellingPrice    Float?
  isActive        Boolean            @default(true)
  menuItemId      String?
  menuItem        InventoryItem?     @relation("RecipeMenuItem", fields: [menuItemId], references: [id])
  ingredients     RecipeIngredient[]
  kitchenOrders   KitchenOrder[]
  businessId      String
  business        Business           @relation(fields: [businessId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([businessId, name])
  @@index([businessId, isActive])
}

model RecipeIngredient {
  id          String        @id @default(uuid())
  recipeId    String
  recipe      Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Float
  unit        String?
  unitCost    Float?
  totalCost   Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([recipeId, itemId])
  @@index([itemId])
}

enum KitchenOrderStatus {
  COMPLETED
  VOIDED
}

model KitchenOrder {
  id          String             @id @default(uuid())
  receiptNo   String
  quantity    Float
  status      KitchenOrderStatus @default(COMPLETED)
  notes       String?
  voidReason  String?
  voidedAt    DateTime?
  recipeId    String
  recipe      Recipe             @relation(fields: [recipeId], references: [id])
  businessId  String
  business    Business           @relation(fields: [businessId], references: [id])
  completedById String?
  completedBy User?              @relation(fields: [completedById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([businessId, receiptNo])
  @@index([businessId, createdAt])
  @@index([businessId, recipeId])
  @@index([businessId, status])
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  SALE
  RECIPE_CONSUMPTION
  SPOILAGE
  EXPIRY
  VOID_RESTOCK
}

model StockMovement {
  id              String            @id @default(uuid())
  type            StockMovementType
  quantity        Float
  previousQuantity Float
  newQuantity     Float
  unit            String?
  reason          String?
  referenceType   String?
  referenceId     String?
  notes           String?
  itemId          String
  item            InventoryItem     @relation(fields: [itemId], references: [id])
  locationId      String
  location        Location          @relation(fields: [locationId], references: [id])
  businessId      String
  business        Business          @relation(fields: [businessId], references: [id])
  createdById     String?
  createdBy       User?             @relation(fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, itemId])
  @@index([businessId, locationId])
  @@index([businessId, type])
}
